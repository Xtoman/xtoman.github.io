---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% for page in site.pages %}{% unless page.url contains '/page/' or page.url == '/404.html' or page.url == '/search/' or page.url == '/photoprojects/' or page.sitemap == false %}{% if page.layout %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ page.url }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
{% endif %}{% endunless %}{% endfor %}
{% for project in site.photoprojects %}{% if project.published != false %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ project.url }}</loc>
    <lastmod>{% if project.date %}{{ project.date | date_to_xmlschema }}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</lastmod>
  </url>
{% endif %}{% endfor %}
{% for post in site.posts %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
    <lastmod>{% if post.updated %}{{ post.updated | date_to_xmlschema }}{% else %}{{ post.date | date_to_xmlschema }}{% endif %}</lastmod>
  </url>
{% endfor %}
</urlset>
