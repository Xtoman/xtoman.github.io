---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
    {% assign page_name = page.path | default: page.name %}
    {% if page.layout != null and page.layout != 'feed' and page.url != '/404.html' and page.url != '/search/' and page.url != '/photoprojects/' %}
    <url>
      <loc>{{ site.url }}{{ site.baseurl }}{{ page.url }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
      <changefreq>{% if page.url == '/' %}weekly{% else %}monthly{% endif %}</changefreq>
      <priority>{% if page.url == '/' %}1.0{% elsif page.url == '/about/' %}0.8{% else %}0.6{% endif %}</priority>
    </url>
    {% endif %}
  {% endfor %}
  {% for project in site.photoprojects %}
    {% if project.published != false %}
    <url>
      <loc>{{ site.url }}{{ site.baseurl }}{{ project.url }}</loc>
      <lastmod>{% if project.date %}{{ project.date | date_to_xmlschema }}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</lastmod>
      <changefreq>monthly</changefreq>
      <priority>0.9</priority>
    </url>
    {% endif %}
  {% endfor %}
  {% for post in site.posts %}
    <url>
      <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
      <lastmod>{% if post.updated %}{{ post.updated | date_to_xmlschema }}{% else %}{{ post.date | date_to_xmlschema }}{% endif %}</lastmod>
      <changefreq>monthly</changefreq>
      <priority>0.7</priority>
    </url>
  {% endfor %}
</urlset>
